{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Levelog",
  "version": "0.1.3",
  "identifier": "com.levelog.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build && pnpm notices:generate",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Levelog",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "日々の活動を成長の証拠へ変えるローカル成長OS",
    "longDescription": "Levelogは、日々の活動とユーザーが確認した証拠を端末内に保存し、次の成長行動を組み立てるmacOSアプリです。",
    "resources": {
      "../LICENSE": "LICENSE",
      "resources/THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
