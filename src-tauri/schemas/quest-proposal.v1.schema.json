{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Levelog QuestProposal v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["templateId", "title", "description", "targetSkillId", "estimatedMinutes", "difficulty", "successCriteria", "evidencePrompt"],
  "properties": {
    "templateId": { "type": "string", "enum": ["clarify_once", "summarize_decision", "explain_simply", "plan_next_step", "review_evidence"] },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "targetSkillId": { "type": "string", "enum": ["thinking.information_structuring", "thinking.problem_decomposition", "thinking.hypothesis_testing", "technical.technical_learning", "technical.system_design", "technical.validation", "communication.clarification", "communication.explanation", "communication.documentation", "execution.prioritization", "execution.planning", "execution.follow_through", "interpersonal.listening", "interpersonal.alignment", "interpersonal.feedback"] },
    "estimatedMinutes": { "type": "integer", "minimum": 5, "maximum": 30 },
    "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
    "successCriteria": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "string", "minLength": 1, "maxLength": 240 } },
    "evidencePrompt": { "type": "string", "minLength": 1, "maxLength": 500 }
  }
}
